dcatapplus:EvaluatedActivity a sh:NodeShape ;
    rdfs:comment "An activity or process that is being evaluated in a DataGeneratingActivity." ;
    sh:closed true ;
    sh:ignoredProperties ( BFO:0000051 schema1:duration RXNO:0000425 SIO:000008 RO:0004008 rdf:type RO:0004009 ) ;
    sh:property [ sh:class dcatapplus:Activity ;
