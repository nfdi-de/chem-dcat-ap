            sh:nodeKind sh:IRI ;
            sh:order 8 ;
            sh:path prov:wasAssociatedWith ],
        [ sh:class dcatapplus:DefinedTerm ;
            sh:description "The slot to specify the ontology class that is instantiated by an entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path rdf:type ],
        [ sh:class dcatapplus:Identifier ;
            sh:description "A slot to provide a secondary identifier of the EvaluatedActivity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path adms:identifier ],
        [ sh:description "A slot to provide an URI for an entity within this schema." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path dcatapplus:id ],
        [ sh:datatype <xsd:string> ;
            sh:description "The slot to provide a description for the Activity." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path dcterms:description ],
        [ sh:datatype <xsd:string> ;
            sh:description "The slot to provide a title for the Activity." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:title ],
        [ sh:class dcatapplus:QualitativeAttribute ;
            sh:description "The slot to relate a qualitative attribute to an EvaluatedEntity, EvaluatedActivity or AgenticEntity" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path dcterms:relation ],
        [ sh:class dcatapplus:Entity ;
            sh:description "The slot to specify the Entity that was used as an input of an Activity that is to be changed, consumed or transformed." ;
            sh:nodeKind sh:IRI ;
            sh:order 5 ;
            sh:path prov:used ],
        [ sh:class dcatapplus:DefinedTerm ;
            sh:description "This slot is described in more detail within the class in which it is used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path dcterms:type ],
        [ sh:class dcatapplus:QuantitativeAttribute ;
            sh:description "The slot to relate a quantitative attribute to an EvaluatedEntity, EvaluatedActivity or AgenticEntity" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path dcterms:relation ] ;
    sh:targetClass prov:Activity .

