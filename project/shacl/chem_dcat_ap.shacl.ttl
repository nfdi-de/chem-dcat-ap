    rdfs:comment "See [DCAT-AP specs:Checksum](https://semiceu.github.io/DCAT-AP/releases/3.0.0/#Checksum)" ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class dcatapplus:ChecksumAlgorithm ;
            sh:description "The algorithm used to produce the subject Checksum." ;
