            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path <spdx:algorithm> ],
        [ sh:datatype <xsd:hexBinary> ;
            sh:description "A lower case hexadecimal encoded digest value produced using a specific algorithm." ;
