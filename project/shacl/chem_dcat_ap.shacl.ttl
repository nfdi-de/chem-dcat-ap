dcatapplus:Surrounding a sh:NodeShape ;
    rdfs:comment "The surrounding in which the dataset creating activity took place (e.g. a lab)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:string> ;
            sh:description "This slot is described in more detail within the class in which it is used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path dcterms:title ],
        [ sh:class dcatapplus:DefinedTerm ;
            sh:description "This slot is described in more detail within the class in which it is used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path dcterms:type ],
        [ sh:datatype <xsd:string> ;
            sh:description "This slot is described in more detail within the class in which it is used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path dcterms:description ],
        [ sh:class dcatapplus:DefinedTerm ;
            sh:description "The slot to specify the ontology class that is instantiated by an entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path rdf:type ] ;
    sh:targetClass prov:Location .

<https://w3id.org/nfdi-de/dcat-ap-plus/materials/MaterialEntity> a sh:NodeShape ;
    rdfs:comment "A material is an Entity that has some portion of matter as proper part." ;
    sh:closed true ;
    sh:ignoredProperties ( BFO:0000051 rdf:type ) ;
    sh:property [ sh:class dcatapplus:QualitativeAttribute ;
            sh:description "The slot to relate a qualitative attribute to an EvaluatedEntity, EvaluatedActivity or AgenticEntity" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path dcterms:relation ],
        [ sh:class dcatapplus:DefinedTerm ;
            sh:description "The slot to specify the ontology class that is instantiated by an entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path rdf:type ],
        [ sh:class <https://w3id.org/nfdi-de/dcat-ap-plus/materials/Temperature> ;
            sh:description "The slot to provide the Temperature of a MaterialEntity or an Activity, whereas the temperature of the Activity is ontologically rooted in the temperature of the material entities that participate in the Activity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path SIO:000008 ],
        [ sh:datatype <xsd:string> ;
            sh:description "The slot to provide a description for the Entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path dcterms:description ],
        [ sh:class <https://w3id.org/nfdi-de/dcat-ap-plus/materials/Pressure> ;
            sh:description "The slot to provide data about the pressure of a MaterialEntity or an Activity, whereas the Pressure of an Activity is ontologically a quality borne by the material entities participating in the Activity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path SIO:000008 ],
        [ sh:class dcatapplus:Entity ;
            sh:description "The slot to specify an Entity of which the Entity is a part." ;
            sh:nodeKind sh:IRI ;
            sh:order 14 ;
            sh:path dcterms:isPartOf ],
        [ sh:class <https://w3id.org/nfdi-de/dcat-ap-plus/materials/Density> ;
            sh:description "The slot to provide the Density of a MaterialEntity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path SIO:000008 ],
        [ sh:datatype <xsd:string> ;
            sh:description "The slot to provide a title for the Entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path dcterms:title ],
        [ sh:class <https://w3id.org/nfdi-de/dcat-ap-plus/materials/MaterialEntity> ;
            sh:description "The slot to provide the parts of a MaterialEntity." ;
            sh:nodeKind sh:IRI ;
            sh:order 13 ;
            sh:path BFO:0000051 ],
        [ sh:class dcatapplus:Identifier ;
            sh:description "A slot to provide a secondary identifier of the Entity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path adms:identifier ],
        [ sh:class <https://w3id.org/nfdi-de/dcat-ap-plus/materials/Mass> ;
            sh:description "The slot to provide the Mass of a MaterialEntity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path SIO:000008 ],
        [ sh:class dcatapplus:DefinedTerm ;
            sh:description "This slot is described in more detail within the class in which it is used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 15 ;
            sh:path dcterms:type ],
        [ sh:class <https://w3id.org/nfdi-de/dcat-ap-plus/materials/Volume> ;
            sh:description "The slot to provide the Volume of a MaterialEntity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path SIO:000008 ],
        [ sh:description "A slot to provide an URI for an entity within this schema." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 9 ;
            sh:path dcatapplus:id ],
        [ sh:datatype <xsd:string> ;
            sh:description "The slot to specify an alternative label, name or title for a MaterialEntity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path skos:altLabel ],
        [ sh:description "The slot to specify the physical state of a MaterialEntity." ;
            sh:in ( PATO:0001736 PATO:0001735 PATO:0001737 PATO:0015012 ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path SIO:000008 ],
        [ sh:class dcatapplus:QuantitativeAttribute ;
            sh:description "The slot to relate a quantitative attribute to an EvaluatedEntity, EvaluatedActivity or AgenticEntity" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path dcterms:relation ] ;
    sh:targetClass BFO:0000040 .

dcatapplus:DatasetSeries a sh:NodeShape ;
    rdfs:comment "See [DCAT-AP specs:DatasetSeries](https://semiceu.github.io/DCAT-AP/releases/3.0.0/#DatasetSeries)" ;
    sh:closed true ;
