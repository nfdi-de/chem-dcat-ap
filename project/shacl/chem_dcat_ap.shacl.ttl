<https://w3id.org/nfdi-de/dcat-ap-plus/chemistry/reaction/ChemicalReaction> a sh:NodeShape ;
    rdfs:comment "A process that leads to the transformation of one set of chemical substances to another and that is the subject matter of a DataGeneratingActivity." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class dcatapplus:Activity ;
            sh:description "The slot to provide an Activity that is part of the Activity." ;
            sh:nodeKind sh:IRI ;
            sh:order 16 ;
            sh:path dcterms:hasPart ],
        [ sh:class <https://w3id.org/nfdi-de/dcat-ap-plus/chemistry/reaction/ChemicalReaction> ;
            sh:description "A slot to specify a step (part) of a ChemicalReaction that is itself a ChemicalReaction." ;
            sh:nodeKind sh:IRI ;
            sh:order 10 ;
            sh:path BFO:0000051 ],
        [ sh:class <https://w3id.org/nfdi-de/dcat-ap-plus/chemistry/reaction/Catalyst> ;
            sh:description "The slot to specify the Catalyst of a ChemicalReaction." ;
            sh:nodeKind sh:IRI ;
            sh:order 3 ;
            sh:path RXNO:0000425 ],
        [ sh:class <https://w3id.org/nfdi-de/dcat-ap-plus/materials/Temperature> ;
            sh:description "The slot to specify the Temperature at which a ChemicalReaction takes place." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path SIO:000008 ],
        [ sh:class <https://w3id.org/nfdi-de/dcat-ap-plus/chemistry/reaction/Reactor> ;
            sh:description "The slot to specify the reactor used in a ChemicalReaction." ;
            sh:nodeKind sh:IRI ;
            sh:order 6 ;
            sh:path prov:wasAssociatedWith ],
        [ sh:class dcatapplus:Activity ;
            sh:description "The slot to provide a previous Activity that informed the Activity by being causally via a shared participant." ;
            sh:nodeKind sh:IRI ;
            sh:order 19 ;
            sh:path prov:wasInformedBy ],
        [ sh:class dcatapplus:AgenticEntity ;
            sh:description "The slot to specify the AgenticEntity that played a certain part in carrying out the Activity, either via having a specific role, function or disposition that was realized in the Activity." ;
            sh:nodeKind sh:IRI ;
            sh:order 20 ;
            sh:path prov:wasAssociatedWith ],
        [ sh:class <https://w3id.org/nfdi-de/dcat-ap-plus/materials/Pressure> ;
            sh:description "The slot to specify the Pressure at which a ChemicalReaction takes place." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path SIO:000008 ],
        [ sh:class dcatapplus:DefinedTerm ;
            sh:description "This slot is described in more detail within the class in which it is used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 24 ;
            sh:path dcterms:type ],
        [ sh:class <https://w3id.org/nfdi-de/dcat-ap-plus/chemistry/reaction/ChemicalProduct> ;
            sh:description "The slot to specify the Product(s) of a ChemicalReaction." ;
            sh:nodeKind sh:IRI ;
            sh:order 2 ;
            sh:path RO:0004008 ],
        [ sh:class dcatapplus:DefinedTerm ;
            sh:description "The slot to specify the ontology class that is instantiated by an entity." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 25 ;
            sh:path rdf:type ],
        [ sh:class dcatapplus:Resource ;
            sh:description "The slot to specify any Documents related to a ChemicalReaction." ;
            sh:nodeKind sh:IRI ;
            sh:order 11 ;
            sh:path dcterms:relation ],
        [ sh:datatype <xsd:string> ;
            sh:description "The slot to provide a title for the Activity." ;
            sh:nodeKind sh:Literal ;
            sh:order 13 ;
            sh:path dcterms:title ],
        [ sh:class dcatapplus:Entity ;
            sh:description "The slot to specify the Entity that was used as an input of an Activity that is to be changed, consumed or transformed." ;
            sh:nodeKind sh:IRI ;
            sh:order 17 ;
            sh:path prov:used ],
        [ sh:class dcatapplus:Identifier ;
            sh:description "A slot to provide a secondary identifier of the EvaluatedActivity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 15 ;
            sh:path adms:identifier ],
        [ sh:class dcatapplus:Entity ;
            sh:description "The slot to specify the Entity that was generated as an output of an Activity." ;
            sh:nodeKind sh:IRI ;
            sh:order 18 ;
            sh:path prov:generated ],
        [ sh:class <https://w3id.org/nfdi-de/dcat-ap-plus/chemistry/reaction/DissolvingSubstance> ;
            sh:description "The slot to specify the chemical substance that had a solvent role (CHEBI:35223) in a ChemicalReaction." ;
            sh:nodeKind sh:IRI ;
            sh:order 4 ;
            sh:path prov:wasAssociatedWith ],
        [ sh:class <https://w3id.org/nfdi-de/dcat-ap-plus/chemistry/reaction/Yield> ;
            sh:description "A slot to provide the percentage of how much of the ChemicalProduct was produced by a ChemicalReaction." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path SIO:000008 ],
        [ sh:class dcatapplus:QuantitativeAttribute ;
            sh:description "The slot to relate a quantitative attribute to an EvaluatedEntity, EvaluatedActivity or AgenticEntity" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 22 ;
            sh:path dcterms:relation ],
        [ sh:description "A slot to provide an URI for an entity within this schema." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:IRI ;
            sh:order 12 ;
            sh:path dcatapplus:id ],
        [ sh:class <https://w3id.org/nfdi-de/dcat-ap-plus/chemistry/reaction/StartingMaterial> ;
            sh:description "The slot to specify the StartingMaterial(s) of a ChemicalReaction." ;
            sh:nodeKind sh:IRI ;
            sh:order 0 ;
            sh:path RO:0004009 ],
        [ sh:class <https://w3id.org/nfdi-de/dcat-ap-plus/chemistry/reaction/Reagent> ;
            sh:description "The slot to specify the Reagent(s) of a ChemicalReaction." ;
            sh:nodeKind sh:IRI ;
            sh:order 1 ;
            sh:path RO:0004009 ],
        [ sh:class dcatapplus:Activity ;
            sh:description "The slot to provide an Activity of which the Activity is a part." ;
            sh:nodeKind sh:IRI ;
            sh:order 23 ;
            sh:path dcterms:isPartOf ],
        [ sh:datatype <xsd:string> ;
            sh:description "The slot to provide a description for the Activity." ;
            sh:nodeKind sh:Literal ;
            sh:order 14 ;
            sh:path dcterms:description ],
        [ sh:datatype <xsd:duration> ;
            sh:description "A slot to provide the duration of a ChemicalReaction." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path schema1:duration ;
            sh:pattern "-?P((([0-9]+Y([0-9]+M)?([0-9]+D)?|([0-9]+M)([0-9]+D)?|([0-9]+D))(T(([0-9]+H)([0-9]+M)?([0-9]+(\\.[0-9]+)?S)?|([0-9]+M)([0-9]+(\\.[0-9]+)?S)?|([0-9]+(\\.[0-9]+)?S)))?)|(T(([0-9]+H)([0-9]+M)?([0-9]+(\\.[0-9]+)?S)?|([0-9]+M)([0-9]+(\\.[0-9]+)?S)?|([0-9]+(\\.[0-9]+)?S))))" ],
        [ sh:class dcatapplus:QualitativeAttribute ;
            sh:description "The slot to relate a qualitative attribute to an EvaluatedEntity, EvaluatedActivity or AgenticEntity" ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 21 ;
            sh:path dcterms:relation ] ;
    sh:targetClass SIO:010345 .

<https://w3id.org/nfdi-de/dcat-ap-plus/chemistry/reaction/MolarEquivalent> a sh:NodeShape ;
    rdfs:comment "A dimensionless ratio that quantifies the stoichiometric proportion of a chemical substance relative to a reference substance in a chemical reaction." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype <xsd:string> ;
