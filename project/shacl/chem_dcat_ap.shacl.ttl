            sh:order 2 ;
            sh:path dcterms:description ],
        [ sh:datatype <xsd:string> ;
            sh:description "A name given to the Dataset Series." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path dcterms:title ],
        [ sh:datatype <xsd:date> ;
            sh:description "The most recent date on which the Dataset Series was changed or modified." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path dcterms:modified ] ;
    sh:targetClass dcat:DatasetSeries .

dcatapplus:EvaluatedEntity a sh:NodeShape ;
