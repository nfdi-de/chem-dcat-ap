        [ sh:class dcatapplus:Location ;
            sh:description "A geographic region that is covered by the Dataset Series." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path dcterms:spatial ],
        [ sh:class dcatapplus:PeriodOfTime ;
