        <https://www.chemotion-repository.net/pid/56408_StartMat-1>,
        <https://www.chemotion-repository.net/pid/56408_StartMat-2> ;
    dcterms:description "The reaction has been conducted in dry glass ware under argon atmosphere. A solution of 1-bromo-2-fluorobenzene (1.76 g, 1.10 mL, 9.86 mmol, 1.08 equiv) in anhydrous THF (24.0 mL) was cooled to -78 °C, and n-BuLi (689 mg, 4.30 mL, 10.8 mmol, 2.50M in hexane, 1.18 equiv) was added drop-wise over 10 min. After stirring for further 50 min, a solution of chloro(diphenyl)phosphine (2.09 g, 1.70 mL, 9.09 mmol, 1.00 equiv) in anhydrous THF (3.00 mL) was added drop-wise over 10 min, and the reaction mixture was stirred for 8 h at -78 °C." ;
    dcterms:hasPart <https://www.chemotion-repository.net/pid/56408#step-1_part-1>,
        <https://www.chemotion-repository.net/pid/56408#step-1_part-2>,
        <https://www.chemotion-repository.net/pid/56408#step-1_part-3>,
        <https://www.chemotion-repository.net/pid/56408#step-1_part-4>,
        <https://www.chemotion-repository.net/pid/56408#step-1_part-5>,
        <https://www.chemotion-repository.net/pid/56408#step-1_part-6> ;
    dcterms:title "Step 1: Lithiation and Phosphination" ;
    schema1:duration "PT9H10M"^^xsd:duration ;
    SIO:000008 [ a qudt:Quantity ;
            dcterms:title "Temperature of reaction step 1" ;
            qudt:hasQuantityKind <http://qudt.org/vocab/quantitykind/Temperature> ;
